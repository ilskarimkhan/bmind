# ============================================
# BMIND SERVER — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# ---- Supabase ----
SUPABASE_URL=YOUR_SUPABASE_URL_HERE
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# ---- Groq AI (Required for message analysis) ----
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# ---- Telegram Bot (Required for Telegram integration) ----
# 1. Open Telegram, search for @BotFather
# 2. Send /newbot and follow the instructions
# 3. Paste the token you receive here
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# ---- Gmail OAuth (Required for Gmail integration) ----
# 1. Go to https://console.cloud.google.com
# 2. Create a project → Enable Gmail API
# 3. Create OAuth 2.0 credentials (Web Application)
# 4. Add redirect URI: http://localhost:3001/api/auth/gmail/callback
GMAIL_CLIENT_ID=YOUR_GMAIL_CLIENT_ID_HERE
GMAIL_CLIENT_SECRET=YOUR_GMAIL_CLIENT_SECRET_HERE
GMAIL_REDIRECT_URI=http://localhost:3001/api/auth/gmail/callback

# ---- Server ----
PORT=3001
NODE_ENV=development
